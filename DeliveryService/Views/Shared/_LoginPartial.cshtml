@using Microsoft.AspNetCore.Identity;
@inject SignInManager<Users> signInManager;


<ul class="navbar-nav ms-auto">
    @if (signInManager.IsSignedIn(User))
    {
        <li class="nav-item">
            <a class="nav-link text-white" asp-area="" asp-controller="Ads" asp-action="Index"><i class="fa-brands fa-buysellads -10"></i> Manage Ads</a>
        </li>
        
        <li class="nav-item">
            <a class="nav-link text-white" asp-area="" asp-controller="StaffInfos" asp-action="Index"><i class="fa-solid fa-clipboard-user"></i> Manage Staff </a>
        </li>



        <li class="nav-item">
            <a class="nav-link text-white" asp-controller="Login" asp-action="Logout"><i class="fa-solid fa-right-from-bracket"></i> <b> Logout</b> </a>
        </li>
    }
    else
    {
       
        <li class="nav-item">
            <a class="nav-link text-white" asp-controller="Login" asp-action="Login"><i class="fa-solid fa-user m-2"></i>  <b> Login</b> </a>
        </li>
        <li class="nav-item">
            <a class="nav-link text-white" asp-controller="Admin" asp-action="AdminLogin"><i class="fa-solid fa-address-card m-2 "></i> <b> Admin</b> </a>
        </li>
    }


</ul>

