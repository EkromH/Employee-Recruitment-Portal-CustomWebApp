@model IEnumerable<DeliveryService.Models.StaffInfo>

@{
    ViewData["Title"] = "Staff Directory";
}

<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<div class="container mt-5 pt-5">
    <div class="d-flex justify-content-between align-items-center mb-2 mt-5">
        <div>
            <h1 class="fw-bold text-dark mb-0">Staff Management</h1>
            <p class="text-muted">Overview of all registered personnel</p>
        </div>
        <a asp-action="Create" class="btn btn-primary rounded-pill px-4 shadow-sm">
            <i class="fas fa-plus me-2"></i>Register New Staff
        </a>
    </div>
    @* =======================================================Search area============= *@
