@model StaffInfo

@{
    ViewData["Title"] = "Delete Staff";
}

<div class="container mt-5 pt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="bg-danger py-4 text-center text-white">
                    <i class="fas fa-exclamation-triangle fa-3x mb-3"></i>
                    <h3 class="fw-bold">Confirm Deletion</h3>
                    <p class="mb-0 opacity-75">This action cannot be undone.</p>
                </div>

                <div class="card-body p-4 text-center">
                    <div class="mb-4">
                        <img src="/AdsImages/@Model.Photo" class="rounded-circle shadow-sm mb-3"
                             style="width: 120px; height: 120px; object-fit: cover; border: 4px solid #f8f9fa;" />
                        <h4 class="fw-bold text-dark">@Model.Name</h4>
                        <p class="text-muted">Staff ID: #@Model.Id.ToString("D4")</p>
                    </div>

                    <div class="alert alert-light border-0 py-3 mb-4">
                        <p class="text-secondary mb-0">
                            Are you sure you want to permanently remove this staff member and their associated records?
                        </p>
                    </div>

                    <form asp-action="Delete">
                        <input type="hidden" asp-for="Id" />

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-danger btn-lg rounded-pill fw-bold shadow-sm">
                                <i class="fas fa-trash-alt me-2"></i>Permanently Delete
                            </button>
                            <a asp-action="Index" class="btn btn-link text-muted fw-bold text-decoration-none">
                                Cancel, Keep Record
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    body {
        background-color: #f8fafc;
        font-family: 'Plus Jakarta Sans', sans-serif;
    }

    .card {
        border: none;
        transition: transform 0.2s ease;
    }

    .btn-danger {
        background-color: #dc3545;
        border: none;
    }

        .btn-danger:hover {
            background-color: #bb2d3b;
            transform: translateY(-1px);
        }
</style>