<style>
    /* Main Layout */
    .info-wrapper, .contact-grid {
        background: #ffffff;
        padding: 2.5rem;
        border-radius: 24px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.05);
        transition: all 0.3s ease;
    }

    /* Icon Shapes */
    .icon-shape {
        width: 60px;
        height: 60px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 18px;
        font-size: 1.5rem;
    }

    .bg-soft-success {
        background: #e8f5e9;
    }

    .bg-soft-danger {
        background: #ffebee;
    }

    /* Mini Cards for Info */
    .mini-card {
        background: #f8f9fa;
        padding: 1rem;
        border-radius: 15px;
        border-bottom: 3px solid #28a745;
    }

    /* Contact Item List */
    .contact-item {
        display: flex;
        align-items: center;
        margin-bottom: 1.5rem;
        padding: 1rem;
        border-radius: 15px;
        transition: background 0.2s;
    }

        .contact-item:hover {
            background: #fff5f5;
        }

    .contact-icon {
        width: 50px;
        height: 50px;
        min-width: 50px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 12px;
        margin-right: 1rem;
    }

    .contact-text h6 {
        margin: 0;
        font-size: 0.85rem;
        color: #6c757d;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    /* Bottom Banner */
    .support-banner {
        padding: 1.2rem;
        border-radius: 18px;
        background: linear-gradient(45deg, #dc3545, #ff4d5d);
    }

    /* Hover effect for the main container */
    .info-wrapper:hover, .contact-grid:hover {
        transform: translateY(-5px);
        box-shadow: 0 20px 40px rgba(0,0,0,0.1);
    }
</style>