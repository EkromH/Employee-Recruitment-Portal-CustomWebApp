@model DeliveryService.ViewModel.RegisterViewModel

@{
    ViewData["Title"] = "Register User";
}

<div class="container-fluid mt-5 pt-5 ">
    <div class="row">
        <div class="col-sm-12 col-md-12 col-lg-6">
            <h1 class="mb-4">Register </h1>
            <form method="post">
                 <div asp-validation-summary="ModelOnly" class="text-danger"> </div>
                 <div class="md-3">
                     <label asp-for="Name" class="form-label"></label>
                     <input asp-for="Name" class="form-control"/>
                     <span asp-validation-for="Name" class="text-danger"></span>
                 </div>
                <div class="md-3">
                    <label asp-for="Email" class="form-label"></label>
                    <input asp-for="Email" class="form-control" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>
                <div class="md-3">
                    <label asp-for="Password" class="form-label"></label>
                    <input asp-for="Password" class="form-control" />
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>
                <div class="md-3">
                    <label asp-for="ConfirmPassword" class="form-label"></label>
                    <input asp-for="ConfirmPassword" class="form-control" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <input type="submit" class="btn btn-primary" value="Register"/>
                </div>

                <div class="mt-4 border-top pt-3">
                    <p class="text-center mb-2">
                        <span class="text-muted">Already have an account?</span>
                        <a asp-controller="Login" asp-action="Login" class="text-decoration-none fw-bold text-primary">Login</a>
                    </p>

                    <div class="text-center">
                        <a asp-controller="Advertisement" asp-action="Index" class="text-decoration-none text-secondary small">
                            <i class="fas fa-arrow-left me-1"></i> Back to Home
                        </a>
                    </div>
                </div>

            </form>

        </div>

    </div>
</div>