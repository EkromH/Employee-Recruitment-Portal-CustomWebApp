@model StaffInfo

@{
    ViewData["Title"] = "Staff Profile";
}

<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<div class="container mt-5 pt-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <a asp-action="Index" class="text-decoration-none text-muted small fw-bold">
                        <i class="fas fa-arrow-left me-1"></i> BACK TO LIST
                    </a>
                    <h2 class="fw-bold text-dark mt-2">Personnel Details</h2>
                </div>
                <div class="d-flex gap-2">
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary rounded-pill px-4 shadow-sm">
                        <i class="fas fa-edit me-2"></i>Edit Profile
                    </a>
                </div>
            </div>

            <div class="row g-4">
                <div class="col-md-4">
                    <div class="card border-0 shadow-sm rounded-4 p-4 text-center">
                        <div class="profile-image-container mb-3">
                            <img src="@(string.IsNullOrEmpty(Model.Photo) ? "/AdsImages/default-avatar.png" : "/AdsImages/" + Model.Photo)"
                                 class="img-fluid rounded-4 shadow-sm profile-img" alt="@Model.Name" />
                        </div>

                        <h4 class="fw-bold mb-1">@Model.Name</h4>
                        <p class="text-muted small mb-3">ID: #@Model.Id.ToString("D4")</p>

                        <span class="badge rounded-pill py-2 px-3 @(Model.Status.ToString() == "Active" ? "bg-success text-success" : "bg-success text-white")">
                            <i class="fas fa-circle me-1 small"></i> @Model.Status
                        </span>

                        <hr class="my-4 opacity-5">

                        <div class="text-start">
                            <p class="mb-1 text-muted small text-uppercase fw-bold">Contact</p>
                            <p class="fw-bold"><i class="fas fa-phone-alt me-2 text-primary"></i>@Model.MobileNumber</p>

                            <p class="mb-1 text-muted small text-uppercase fw-bold mt-3">Joined On</p>
                            <p class="fw-bold"><i class="fas fa-calendar-alt me-2 text-primary"></i>@Model.Date.ToString("dd MMM, yyyy")</p>
                        </div>
                    </div>
                </div>

                <div class="col-md-8">
                    <div class="card border-0 shadow-sm rounded-4 p-4">
                        <h5 class="fw-bold mb-4 border-bottom pb-2">
                            <i class="fas fa-id-card me-2 text-primary"></i>Identity & Family
                        </h5>

                        <div class="row g-4">
                            <div class="col-sm-6">
                                <label class="text-muted small text-uppercase d-block">Passport Number</label>
                                <span class="fw-semibold">@(Model.PassportNo ?? "N/A")</span>
                            </div>

                            <div class="col-sm-6">
                                <label class="text-muted small text-uppercase d-block">Employment Status</label>
                                <span class="fw-semibold">@Model.Status</span>
                            </div>

                            <div class="col-sm-6">
                                <label class="text-muted small text-uppercase d-block">Father's Name</label>
                                <span class="fw-semibold">@(Model.FathersName ?? "---")</span>
                            </div>

                            <div class="col-sm-6">
                                <label class="text-muted small text-uppercase d-block">Mother's Name</label>
                                <span class="fw-semibold">@(Model.MothersName ?? "---")</span>
                            </div>
                        </div>

                        <div class="alert alert-light mt-5 border-0 rounded-4 p-4">
                            <h6 class="fw-bold"><i class="fas fa-info-circle me-2"></i>Data Integrity</h6>
                            <p class="small text-muted mb-0">
                                This profile was last verified on @DateTime.Now.ToString("yyyy-MM-dd"). All personal information is encrypted and stored according to company privacy policies.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    body {
        font-family: 'Plus Jakarta Sans', sans-serif;
        background-color: #f8fafc;
    }

    .profile-img {
        width: 100%;
        height: 250px;
        object-fit: cover;
        background: #f1f5f9;
    }

    /* Soft Badges */
    .bg-success-light {
        background-color: #dcfce7;
        color: #166534;
    }

    .bg-warning-light {
        background-color: #fef9c3;
        color: #854d0e;
    }

    .btn-primary {
        background: #2563eb;
        border: none;
        transition: all 0.2s;
    }

        .btn-primary:hover {
            background: #1d4ed8;
            transform: translateY(-1px);
        }

    label {
        margin-bottom: 2px;
    }

    span.fw-semibold {
        font-size: 1.1rem;
        color: #1e293b;
    }
</style>