@model IEnumerable<DeliveryService.Models.StaffInfo>

@{
    ViewData["Title"] = "Search Staff";
}

<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<div class="container mt-5 pt-5 style">
    <h2 class="mb-4">
        <b>
            Check Your Status <br />
        </b>
        <hr />
        Search Recruitment Status by Passport No / Mobile Number
    </h2>

    <form asp-action="Search" method="post" class="mb-4">
        <div class="input-group">
            <input type="text" name="query" class="form-control" placeholder="Enter Passport No or Mobile Number" required />
            <button type="submit" class="btn btn-primary">Search</button>
        </div>
    </form>

    @if (Model != null && Model.Any())
    {
        <h4 class="mb-4">Search Results (@Model.Count())</h4>

        <div class="row g-4">
            @foreach (var item in Model)
            {
                <div class="col-xl-3 col-lg-4 col-md-6">
                    <div class="staff-card border-0 shadow-sm rounded-4 overflow-hidden bg-white h-100">
                        <div class="position-relative" style="height: 250px;">
                            <img src="~/AdsImages/@item.Photo"
                                 class="w-100 h-100 object-fit-cover"
                                 alt="@item.Name"
                                 onerror="this.src='/AdsImages/default-avatar.png';" />

                            <span class="badge position-absolute top-0 end-0 m-3 px-3 py-2 rounded-pill @(item.Status == DeliveryService.Models.Enums.StaffStatus.Appointed ? "bg-success text-white" : "bg-secondary text-white") shadow-sm small fw-bold">
                                @item.Status
                            </span>
                        </div>

                        <div class="p-4">
                            <h5 class="fw-bold text-dark mb-1">@item.Name</h5>
                            <p class="text-muted small mb-3">
                                <i class="fas fa-passport me-2"></i>@item.PassportNo <br />
                                @* <i class="fas fa-phone me-2"></i>@item.MobileNumber *@
                            </p>

                            <div class="bg-light p-3 rounded-3 mb-4">
                                <div class="d-flex justify-content-between small">
                                    <span class="text-muted">Apply Date:</span>
                                    <span class="fw-bold">@item.Date.ToString("MMM dd, yyyy")</span>
                                </div>
                            </div>

                            <div class="d-flex gap-2">
                                <a asp-action="DetailsSearch" asp-route-id="@item.Id" class="btn btn-outline-secondary btn-sm flex-grow-1 rounded-pill">Details</a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else if (Model != null)
    {
        <p class="text-muted mt-4">No staff found for your search query.</p>
    }
</div>

